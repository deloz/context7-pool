  "query": "\n            UPDATE api_keys\n            SET health_status = 'healthy',\n                failure_streak = 0,\n                cooldown_until = NULL,\n                last_error = NULL,\n                last_status_code = NULL,\n                updated_at = $2\n            WHERE id = $1\n            RETURNING id, name, api_key, enabled, health_status, failure_streak,\n                      cooldown_until, last_error, last_status_code, last_success_at,\n                      created_at, updated_at\n            ",
